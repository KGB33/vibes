#!/usr/bin/env bash
# SessionStart hook for the workflow plugin. Requires jq.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if ! command -v jq >/dev/null 2>&1; then
  printf '{"additionalContext": "workflow plugin session-start hook: jq not found on PATH; skill context was not injected. Install jq on this machine."}\n'
  exit 0
fi

using_skills_content=$(cat "${PLUGIN_ROOT}/skills/using-skills/SKILL.md" 2>&1 || echo "Error reading using-skills skill")

session_context="<EXTREMELY_IMPORTANT>
These are your workflow skills.

**Below is the full content of your 'workflow:using-skills' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**

${using_skills_content}
</EXTREMELY_IMPORTANT>"

# Claude Code expects hookSpecificOutput.additionalContext (nested); any other
# platform that runs this hook gets the SDK-standard top-level additionalContext.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  jq -n --arg ctx "$session_context" \
    '{hookSpecificOutput: {hookEventName: "SessionStart", additionalContext: $ctx}}'
else
  jq -n --arg ctx "$session_context" '{additionalContext: $ctx}'
fi

exit 0
